# Database
DB_USER=directus
DB_PASSWORD=directus
DB_DATABASE=directus

# Directus
DIRECTUS_PORT=8055
DIRECTUS_SECRET=6116487b-cda1-52c2-b5b5-c8022c45e263

# Cache
CACHE_ENABLED=true
CACHE_AUTO_PURGE=true

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=d1r3ctu5

# WebSocket
WEBSOCKETS_ENABLED=true
WEBSOCKETS_COLLAB_ENABLED=true
LOG_LEVEL=info

# Directus Public URL
PUBLIC_URL=http://localhost:8055

# CORS
CORS_ENABLED=true
CORS_ORIGIN=*

# Cookies (production: set secure=true, domain=.yourdomain.com)
REFRESH_TOKEN_COOKIE_SECURE=false
REFRESH_TOKEN_COOKIE_SAME_SITE=lax
REFRESH_TOKEN_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_DOMAIN=localhost

# Extensions
EXTENSIONS_PATH=./extensions
EXTENSIONS_AUTO_RELOAD=true
EXTENSIONS_ROLLDOWN=true

# Content Security Policy
CONTENT_SECURITY_POLICY_DIRECTIVES__FRAME_SRC=http://localhost:3000,http://localhost:4321,http://localhost:5173,https://*.youtube.com,https://*.vimeo.com,https://*.wistia.net,https://*.loom.com

# Email (use "log" in dev to avoid health check errors)
EMAIL_TRANSPORT=log
EMAIL_FROM=admin@example.com
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# Frontend build args for Docker
# Production: PUBLIC_DIRECTUS_URL=https://directus.yourdomain.com
#             PUBLIC_SITE_URL=https://yourdomain.com
PUBLIC_DIRECTUS_URL=http://localhost:8055
PUBLIC_SITE_URL=http://localhost:3000
DIRECTUS_SERVER_TOKEN=dev-server-token
